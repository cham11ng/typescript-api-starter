{
  "name": "typescript-api-starter",
  "version": "1.0.0",
  "description": "Starter for Node.js express API with Typescript",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:cham11ng/typescript-api-starter.git"
  },
  "author": {
    "name": "Sagar Chamling",
    "email": "sgr.raee@gmail.com"
  },
  "scripts": {
    "start": "bun --watch run src/index.ts",
    "transpile": "tsc",
    "clean": "rimraf build",
    "sync-env": "sync-dotenv",
    "build": "concurrently 'bun clean' 'bun lint:fix' 'bun build '",
    "send:mail": "ts-node scripts/mail-test",
    "load:fake": "ts-node scripts/fake-loader",
    "t": "NODE_ENV=test bun test",
    "test": "NODE_ENV=test bun migrate && NODE_ENV=test bun test --forceExit --detectOpenHandles --maxWorkers=1 --verbose",
    "seed": "knex seed:run --knexfile=knexfile.ts --verbose",
    "migrate": "knex migrate:latest --knexfile=knexfile.ts --verbose",
    "rollback": "knex migrate:rollback --knexfile=knexfile.ts --verbose",
    "make:seeder": "knex seed:make --knexfile=knexfile.ts -x ts",
    "make:migration": "knex migrate:make --knexfile=knexfile.ts -x ts",
    "prepare": "husky install",
    "lint": "eslint . --ext .ts,.json",
    "lint:fix": "eslint --fix . --ext .ts,.json",
    "prettify": "prettier 'src/**/*.ts' --write",
    "prettier:check": "prettier --list-different 'src/**/*.ts'",
    "format:code": "concurrently 'bun lint:fix' 'bun prettify' 'sync-dotenv'"
  },
  "lint-staged": {
    "*.{ts,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "private": true,
  "license": "MIT",
  "keywords": [
    "api",
    "es6",
    "node",
    "express",
    "javascript",
    "typescript"
  ],
  "dependencies": {
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "4.18.2",
    "helmet": "^7.0.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.10.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^2.5.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.5",
    "nodemailer-markdown": "^1.0.3",
    "objection": "^3.1.2",
    "pg": "^8.11.3",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.5.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.1.0",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/morgan": "^1.9.6",
    "@types/nodemailer": "^6.4.11",
    "@types/supertest": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "bun-types": "^1.0.3",
    "chalk": "^5.3.0",
    "concurrently": "^8.2.1",
    "eslint": "^8.50.0",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "sync-dotenv": "^2.6.2",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2"
  }
}
